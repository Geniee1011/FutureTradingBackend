# Copy to .env and fill in.

# Port the backend listens on (HTTP /api/history + WebSocket /ws).
PORT=8000

# Allowed CORS origin for the REST history endpoint (the frontend dev server).
CORS_ORIGIN=http://localhost:3000

# --- Auth (JWT) ---
# Secret used to sign JWTs. MUST be set to a long random string in production.
JWT_SECRET=
# Token lifetime in seconds (default 7 days).
JWT_EXPIRES_IN_SEC=604800

# --- Bootstrap admin (optional) ---
# When BOTH are set, the backend ensures an ADMIN user with this email exists on
# startup (creates it, or promotes an existing user of that email to ADMIN). Lets
# you provision an admin on a fresh deploy without the seed or a shell. The
# Register page only creates traders, so this is how you get an admin account.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# PostgreSQL connection for Prisma (leave blank to use the seeded in-memory users).
DATABASE_URL=

# Auto-seed demo data on a FRESH (empty) database at first boot. Set to 1 ONLY for
# a demo deploy — it creates well-known demo credentials (admin@demo.com /
# trader@demo.com / demo). Leave blank/unset in production. Once the DB has any
# account it never re-seeds (won't overwrite real data).
SEED_DEMO=

# --- Market-data model ---
# How market data is delivered (and licensed):
#   shared = Model A: one master DATABENTO_API_KEY, fanned out to all users
#            (simple; counts as redistribution → needs a redistribution license).
#   byo    = Model B: each user brings their own Databento account; the app
#            streams only data their own license covers (no redistribution).
# Default is "shared". Model B "byo" is implemented end-to-end: set this to "byo"
# (and set MARKET_DATA_ENC_KEY below) and each user connects their own Databento
# key in-app (avatar menu → Databento account); charts then stream from their key.
MARKET_DATA_MODE=shared

# Secret used to ENCRYPT each user's stored Databento key at rest (Model B only).
# Any long random string. Required when MARKET_DATA_MODE=byo.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
MARKET_DATA_ENC_KEY=

# --- Databento ---
# Get a key at https://databento.com (Portal → API keys). Real-time CME data
# also requires a CME market-data subscription on your Databento account.
# Leave BLANK to run in simulation mode (random-walk prices, no account needed).
# Used by Model A (shared). Under Model B (byo) each user supplies their own key.
DATABENTO_API_KEY=

# CME Globex dataset. Do not change unless you know what you're doing.
DATABENTO_DATASET=GLBX.MDP3

# How often (ms) to poll the latest trade for each symbol (near-real-time).
QUOTE_POLL_MS=1500
