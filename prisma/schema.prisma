// Trading Evaluation Platform — Prisma schema (PostgreSQL).
// Mirrors DATABASE_SCHEMA.md: User → Account → (Rule, Position, Order → Fill,
// Violation, ActivityLog). Money uses Decimal(18,2); prices Decimal(18,4) to
// cover futures ticks (ES 0.25, CL 0.01, GC 0.1); quantities are whole contracts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums ------------------------------

enum Role {
  ADMIN
  TRADER
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum AccountStatus {
  ACTIVE
  PASSED
  FAILED
  SUSPENDED
}

enum PositionSide {
  LONG
  SHORT
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
  STOP_LIMIT
}

enum OrderStatus {
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  REJECTED
}

enum ViolationType {
  DAILY_LOSS_EXCEEDED
  MAX_DRAWDOWN_BREACHED
  CONTRACT_LIMIT_EXCEEDED
  RESTRICTED_INSTRUMENT
}

enum ViolationAction {
  REJECT_ORDER
  LIQUIDATE_POSITION
  SUSPEND_ACCOUNT
}

enum ActivityType {
  USER_LOGIN
  ORDER_PLACEMENT
  ORDER_FILLED
  ORDER_CANCELLED
  ORDER_REJECTED
  POSITION_OPENED
  POSITION_CLOSED
  RULE_VIOLATION
  ACCOUNT_PASSED
  ACCOUNT_SUSPENSION
}

// ----------------------------- Models -----------------------------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         Role       @default(TRADER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  account Account?

  @@index([role, status])
}

model Account {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startingBalance Decimal       @db.Decimal(18, 2)
  balance         Decimal       @db.Decimal(18, 2)
  equity          Decimal       @db.Decimal(18, 2)
  dailyPnl        Decimal       @default(0) @db.Decimal(18, 2)
  totalPnl        Decimal       @default(0) @db.Decimal(18, 2)
  drawdown        Decimal       @default(0) @db.Decimal(18, 2)
  highestEquity   Decimal       @db.Decimal(18, 2)
  status          AccountStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  rule         Rule?
  positions    Position[]
  orders       Order[]
  violations   Violation[]
  activityLogs ActivityLog[]

  @@index([status])
}

model Rule {
  id                 String   @id @default(cuid())
  accountId          String   @unique
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  maxDailyLoss       Decimal  @db.Decimal(18, 2) // absolute loss limit per day
  maxDrawdown        Decimal  @db.Decimal(18, 2) // max equity drawdown
  profitTarget       Decimal  @db.Decimal(18, 2) // pass threshold
  maxContracts       Int // max net contracts per position
  allowedInstruments String[] // empty = all allowed
  updatedAt          DateTime @updatedAt
}

model Position {
  id            String       @id @default(cuid())
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol        String
  side          PositionSide
  quantity      Int
  averagePrice  Decimal      @db.Decimal(18, 4)
  unrealizedPnl Decimal      @default(0) @db.Decimal(18, 2)
  realizedPnl   Decimal      @default(0) @db.Decimal(18, 2)
  openedAt      DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([accountId, symbol]) // one net position per symbol per account
  @@index([accountId])
}

model Order {
  id             String      @id @default(cuid())
  accountId      String
  account        Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol         String
  side           OrderSide
  type           OrderType
  quantity       Int
  filledQuantity Int         @default(0)
  requestedPrice Decimal?    @db.Decimal(18, 4) // limit price
  stopPrice      Decimal?    @db.Decimal(18, 4) // stop trigger
  fillPrice      Decimal?    @db.Decimal(18, 4) // avg fill
  status         OrderStatus @default(PENDING)
  reason         String? // populated on reject/cancel
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  fills Fill[]

  @@index([accountId, status])
  @@index([symbol, status])
}

model Fill {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now())

  @@index([orderId])
}

model Violation {
  id        String          @id @default(cuid())
  accountId String
  account   Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type      ViolationType
  action    ViolationAction
  detail    String?
  createdAt DateTime        @default(now())

  @@index([accountId])
}

model ActivityLog {
  id        String       @id @default(cuid())
  accountId String?
  account   Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  type      ActivityType
  message   String
  metadata  Json?
  ip        String?
  createdAt DateTime     @default(now())

  @@index([accountId, createdAt])
  @@index([type])
}
